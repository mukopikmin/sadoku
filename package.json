{
  "name": "sadoku",
  "description": "Preview a Markdown file in a local browser-friendly server.",
  "private": true,
  "scripts": {
    "build:client": "npm --prefix src/preview run build",
    "install:deps": "npm ci --ignore-scripts && npm ci --prefix src/preview",
    "postinstall": "npm ci --prefix src/preview",
    "test": "npm --prefix src/preview test"
  }
}
